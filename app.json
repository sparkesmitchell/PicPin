{
  "expo": {
    "name": "PicPins",
    "slug": "picpins",
    "version": "1.0.3",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "pinnotes",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mitchellsparkes.picpins",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "PicPins uses your camera to take photos that you can annotate with pins and notes for documentation purposes.",
        "NSPhotoLibraryUsageDescription": "PicPins accesses your photo library so you can import existing photos to annotate with pins and notes.",
        "NSPhotoLibraryAddUsageDescription": "PicPins saves your annotated photos to your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.mitchellsparkes.picpins"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-screen-orientation",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1a1a2e",
          "dark": {
            "backgroundColor": "#1a1a2e"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6120fad7-0125-4bd7-b6e1-93c85b3c00c3"
      }
    },
    "owner": "mitchellsparkes",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/6120fad7-0125-4bd7-b6e1-93c85b3c00c3"
    }
  }
}
